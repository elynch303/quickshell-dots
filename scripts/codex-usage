#!/usr/bin/env python3
"""
OpenAI Codex quota for the Quickshell bar widget.

Reads the authoritative rate limits the Codex CLI exposes via its local
app-server JSON-RPC (account/rateLimits/read), falling back to the newest
recorded session rollout. Codex can expose multiple independent limit buckets,
so the cache stores bucket/window metadata instead of assuming Claude's fixed
5h/7d model.
"""
import json, os, select, shutil, subprocess, sys, time
from datetime import datetime, timezone
from pathlib import Path

CODEX_HOME = Path(os.environ.get("CODEX_HOME") or (Path.home() / ".codex"))
CACHE_FILE = Path(os.environ.get("CODEX_USAGE_CACHE_FILE") or (Path.home() / ".cache" / "codex-usage.json"))
ACTIVITY_FILE = Path(os.environ.get("CODEX_USAGE_ACTIVITY_FILE") or (Path.home() / ".cache" / "codex-usage-activity.json"))
ACTIVITY_SCHEMA_VERSION = 2
RESET_PLAUSIBILITY_SLOP_SECS = 600
EVENT_CLOCK_SKEW_SECS = 120


def now_epoch() -> float:
    try:
        return float(os.environ.get("CODEX_USAGE_NOW") or time.time())
    except Exception:
        return time.time()


def atomic_write_json(path: Path, obj: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    tmp.write_text(json.dumps(obj, separators=(",", ":")) + "\n")
    os.replace(tmp, path)


def runtime_env() -> dict:
    home = str(Path.home())
    parts = [os.environ.get("PATH", ""), f"{home}/.local/bin",
             f"{home}/.npm-global/bin", f"{home}/.local/share/mise/shims"]
    env = os.environ.copy()
    env["PATH"] = os.pathsep.join(p for p in parts if p)
    return env


ENV = runtime_env()


def find_codex() -> str | None:
    return shutil.which("codex", path=ENV.get("PATH"))


def fetch_env() -> dict | None:
    raw = os.environ.get("CODEX_USAGE_RATE_LIMITS_JSON")
    if not raw:
        return None
    try:
        data = json.loads(raw)
    except Exception as e:
        sys.stderr.write(f"env rate limit JSON failed: {e}\n")
        return None
    if "rateLimits" in data or "rateLimitsByLimitId" in data:
        return {
            "rateLimits": data.get("rateLimits") or {},
            "rateLimitsByLimitId": data.get("rateLimitsByLimitId"),
            "plan": data.get("plan_type") or data.get("planType") or data.get("plan") or "",
            "source": data.get("source") or "fixture",
        }
    snapshot = {
        "limitId": data.get("limitId") or "codex",
        "limitName": data.get("limitName"),
        "planType": data.get("plan_type") or data.get("planType") or data.get("plan") or "",
        "primary": data.get("primary") or {},
        "secondary": data.get("secondary") or {},
    }
    return {
        "rateLimits": snapshot,
        "rateLimitsByLimitId": None,
        "plan": snapshot.get("planType") or "",
        "source": data.get("source") or "fixture",
    }


# ── authoritative live limits via the Codex app-server JSON-RPC ──
def rpc_request(proc, request_id, method, params=None, timeout=8):
    proc.stdin.write(json.dumps({"id": request_id, "method": method,
                                 "params": params or {}}) + "\n")
    proc.stdin.flush()
    deadline = time.time() + timeout
    while time.time() < deadline:
        ready, _, _ = select.select([proc.stdout], [], [], 0.25)
        if not ready:
            continue
        line = proc.stdout.readline()
        if not line:
            break
        try:
            msg = json.loads(line)
        except Exception:
            continue
        if msg.get("id") == request_id:
            return msg
    raise TimeoutError(method)


def fetch_rpc() -> dict | None:
    if os.environ.get("CODEX_USAGE_DISABLE_RPC") == "1":
        return None
    codex = find_codex()
    if not codex:
        return None
    try:
        proc = subprocess.Popen(
            [codex, "-s", "read-only", "-a", "untrusted", "app-server"],
            stdin=subprocess.PIPE, stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL, text=True, env=ENV)
    except Exception as e:
        sys.stderr.write(f"app-server spawn failed: {e}\n")
        return None
    try:
        rpc_request(proc, 1, "initialize",
                    {"clientInfo": {"name": "codex-usage", "version": "1"}}, timeout=8)
        proc.stdin.write(json.dumps({"method": "initialized", "params": {}}) + "\n")
        proc.stdin.flush()
        account = (rpc_request(proc, 2, "account/read", timeout=5)
                   .get("result") or {}).get("account") or {}
        rate_limits_result = (rpc_request(proc, 3, "account/rateLimits/read", timeout=5)
                              .get("result") or {})
    except Exception as e:
        sys.stderr.write(f"rpc error: {e}\n")
        return None
    finally:
        try:
            proc.terminate(); proc.wait(timeout=1)
        except Exception:
            try:
                proc.kill()
            except Exception:
                pass

    limits = rate_limits_result.get("rateLimits") or {}
    by_limit = rate_limits_result.get("rateLimitsByLimitId")
    primary = limits.get("primary") or {}
    secondary = limits.get("secondary") or {}
    if primary.get("usedPercent") is None and secondary.get("usedPercent") is None and not by_limit:
        return None
    return {
        "rateLimits": limits,
        "rateLimitsByLimitId": by_limit,
        "plan": limits.get("planType") or account.get("planType") or account.get("type") or "",
        "source": "rpc",
    }


# ── fallback: newest canonical general-Codex snapshot from session rollouts ──
def fetch_rollout() -> dict | None:
    roots = [CODEX_HOME / "sessions", CODEX_HOME / "archived_sessions"]
    best = None
    best_ts = 0.0

    for root in roots:
        if not root.exists():
            continue
        for path in root.rglob("*.jsonl"):
            try:
                with path.open(errors="replace") as fh:
                    for raw in fh:
                        if '"rate_limits"' not in raw:
                            continue
                        try:
                            ev = json.loads(raw)
                        except Exception:
                            continue
                        rl = (ev.get("payload") or {}).get("rate_limits")
                        if not isinstance(rl, dict) or rl.get("limit_id") != "codex":
                            continue
                        ts = iso_epoch(str(ev.get("timestamp") or ""))
                        if ts >= best_ts:
                            best = rl
                            best_ts = ts
            except OSError:
                continue

    if not best:
        return None

    def conv(window):
        if not isinstance(window, dict):
            return {}
        return {"usedPercent": window.get("used_percent"),
                "windowDurationMins": window.get("window_minutes"),
                "resetsAt": window.get("resets_at")}

    snapshot = {
        "limitId": best.get("limit_id") or best.get("limitId") or "codex",
        "limitName": best.get("limit_name") or best.get("limitName"),
        "planType": best.get("plan_type") or best.get("planType") or "",
        "primary": conv(best.get("primary")),
        "secondary": conv(best.get("secondary")),
    }
    return {
        "rateLimits": snapshot,
        "rateLimitsByLimitId": best.get("rate_limits_by_limit_id") or best.get("rateLimitsByLimitId"),
        "plan": snapshot.get("planType") or "",
        "source": "rollout",
    }


# ── light "today" token estimate from today's rollouts (per-call deltas) ──
def iso_epoch(s: str) -> float:
    try:
        if s.endswith("Z"):
            s = s[:-1] + "+00:00"
        return datetime.fromisoformat(s).timestamp()
    except Exception:
        return 0.0


def reset_epoch(window) -> int:
    try:
        return int(window.get("resetsAt") or 0)
    except Exception:
        return 0


def as_float(v, default=0.0) -> float:
    try:
        return float(v)
    except Exception:
        return default


def as_int(v, default=0) -> int:
    try:
        return int(v)
    except Exception:
        return default


def window_label(minutes: int) -> str:
    if minutes == 300:
        return "5h"
    if minutes == 10080:
        return "Weekly"
    if minutes > 0 and minutes % 1440 == 0:
        return f"{minutes // 1440}d"
    if minutes > 0 and minutes % 60 == 0:
        return f"{minutes // 60}h"
    return f"{minutes}m" if minutes > 0 else "window"


def window_field(window: dict, camel: str, snake: str):
    if not isinstance(window, dict):
        return None
    return window.get(camel) if window.get(camel) is not None else window.get(snake)


def normalize_window(kind: str, window: dict) -> dict | None:
    if not isinstance(window, dict) or not window:
        return None
    used = window_field(window, "usedPercent", "used_percent")
    minutes = as_int(window_field(window, "windowDurationMins", "window_minutes"))
    reset = as_int(window_field(window, "resetsAt", "resets_at"))
    if used is None or minutes <= 0:
        return None
    util = max(0.0, min(1.0, as_float(used) / 100.0))
    return {
        "kind": kind,
        "minutes": minutes,
        "label": window_label(minutes),
        "utilization": round(util, 6),
        "reset": reset,
    }


def normalize_windows(snapshot: dict) -> list[dict]:
    windows = []
    primary = normalize_window("primary", snapshot.get("primary") or {})
    secondary = normalize_window("secondary", snapshot.get("secondary") or {})
    if primary:
        windows.append(primary)
    if secondary:
        windows.append(secondary)
    return windows


def sort_windows(windows: list[dict]) -> list[dict]:
    order = {300: 0, 10080: 1}
    return sorted(windows, key=lambda w: (order.get(as_int(w.get("minutes")), 99),
                                          as_int(w.get("minutes"))))


def snapshot_id(snapshot: dict, fallback: str = "") -> str:
    if not isinstance(snapshot, dict):
        return fallback
    return str(snapshot.get("limitId") or snapshot.get("limit_id") or fallback or "")


def snapshot_name(snapshot: dict, bucket_id: str, is_general: bool) -> str:
    if not isinstance(snapshot, dict):
        return "Codex" if is_general else bucket_id
    name = snapshot.get("limitName") or snapshot.get("limit_name")
    if name:
        return str(name)
    if is_general or bucket_id == "codex":
        return "Codex"
    return bucket_id


def normalize_bucket(bucket_id: str, snapshot: dict, is_general: bool = False) -> dict | None:
    if not isinstance(snapshot, dict):
        return None
    bid = snapshot_id(snapshot, bucket_id)
    if not bid:
        bid = "codex" if is_general else bucket_id
    windows = normalize_windows(snapshot)
    if not windows:
        return None
    bucket = {
        "id": bid,
        "label": snapshot_name(snapshot, bid, is_general),
        "isGeneral": bool(is_general or bid == "codex"),
        "windows": windows,
    }
    plan = snapshot.get("planType") or snapshot.get("plan_type")
    if plan:
        bucket["plan"] = str(plan)
    reached_type = snapshot.get("rateLimitReachedType") or snapshot.get("rate_limit_reached_type")
    if reached_type:
        bucket["rateLimitReachedType"] = str(reached_type)
    return bucket


def normalize_buckets(data: dict) -> list[dict]:
    general = data.get("rateLimits") if isinstance(data.get("rateLimits"), dict) else {}
    by_id = data.get("rateLimitsByLimitId")
    buckets = []
    seen = set()

    if isinstance(by_id, dict) and by_id:
        keys = []
        if "codex" in by_id:
            keys.append("codex")
        keys.extend(k for k in by_id.keys() if k != "codex")
        for key in keys:
            snap = by_id.get(key) or {}
            bucket = normalize_bucket(str(key), snap, str(key) == "codex")
            if bucket and bucket["id"] not in seen:
                buckets.append(bucket)
                seen.add(bucket["id"])

    if "codex" not in seen and general:
        general_id = snapshot_id(general, "codex")
        bucket = normalize_bucket(general_id, general, general_id == "codex")
        if bucket and bucket["id"] not in seen:
            buckets.insert(0, bucket)
            seen.add(bucket["id"])

    if not buckets and (data.get("primary") or data.get("secondary")):
        fallback_id = snapshot_id(data, "codex")
        bucket = normalize_bucket(fallback_id, data, fallback_id == "codex")
        if bucket:
            buckets.append(bucket)

    return buckets


def general_bucket(buckets: list[dict]) -> dict:
    for bucket in buckets:
        if bucket.get("isGeneral") or bucket.get("id") == "codex":
            return bucket
    return {}


def valid_session_rate_limit_window(rate_limits: dict, window: dict, minutes: int,
                                    timestamp: str, now: float) -> bool:
    if not isinstance(rate_limits, dict) or rate_limits.get("limit_id") != "codex":
        return False
    if not isinstance(window, dict) or window.get("used_percent") is None:
        return False
    reset = as_int(window.get("resets_at"))
    if reset <= now:
        return False
    event_ts = iso_epoch(timestamp)
    if event_ts <= 0 or reset <= event_ts:
        return False
    if event_ts > now + EVENT_CLOCK_SKEW_SECS:
        return False
    max_delta = minutes * 60 + RESET_PLAUSIBILITY_SLOP_SECS
    return reset - event_ts <= max_delta


def session_rate_limit_candidates(rate_limits: dict, timestamp: str, now: float) -> list[dict]:
    candidates = []
    for key, legacy_minutes in (("primary", 300), ("secondary", 10080)):
        window = dict(rate_limits.get(key) or {})
        minutes = as_int(window.get("window_minutes") or legacy_minutes)
        if minutes <= 0:
            continue
        if not valid_session_rate_limit_window(rate_limits, window, minutes, timestamp, now):
            continue
        window.setdefault("window_minutes", minutes)
        candidate = normalize_window(key, window)
        if not candidate:
            continue
        candidate["source"] = "session"
        candidate["_timestamp"] = timestamp
        candidate["_eventEpoch"] = iso_epoch(timestamp)
        candidates.append(candidate)
    return candidates


def supplement_missing_general_windows_from_sessions(buckets: list[dict],
                                                     session_windows: dict[int, dict]) -> None:
    """Fill missing general Codex windows from validated session snapshots.

    The live app-server RPC remains authoritative. Session logs are historical
    snapshots, so this only supplements missing windows from canonical,
    non-expired, reset-plausible `limit_id == codex` events.
    """
    general = general_bucket(buckets)
    if not general:
        return
    existing = {as_int(w.get("minutes")) for w in general.get("windows") or []}
    wanted = {300, 10080} - existing
    if not wanted:
        general["windows"] = sort_windows(general.get("windows") or [])
        return
    if not session_windows:
        general["windows"] = sort_windows(general.get("windows") or [])
        return
    merged = list(general.get("windows") or [])
    for minutes in sorted(wanted):
        if minutes not in session_windows:
            continue
        window = dict(session_windows[minutes])
        window.pop("_timestamp", None)
        window.pop("_eventEpoch", None)
        merged.append(window)
    general["windows"] = sort_windows(merged)


def quota_window(bucket: dict) -> tuple[float, str, str]:
    max_util = 0.0
    bucket_label = str(bucket.get("label") or bucket.get("id") or "Codex") if bucket else ""
    window_label_value = ""
    for window in bucket.get("windows") or []:
        util = as_float(window.get("utilization"))
        if util > max_util:
            max_util = util
            window_label_value = str(window.get("label") or "window")
    return max_util, bucket_label, window_label_value


def token_total(info: dict) -> int | None:
    if not isinstance(info, dict):
        return None
    for key in ("total_token_usage", "totalTokenUsage", "token_usage", "tokenUsage"):
        total = info.get(key)
        if isinstance(total, dict) and total.get("total_tokens") is not None:
            return as_int(total.get("total_tokens"))
    return None


def token_last(info: dict) -> int:
    if not isinstance(info, dict):
        return 0
    for key in ("last_token_usage", "lastTokenUsage"):
        last = info.get(key)
        if isinstance(last, dict) and last.get("total_tokens") is not None:
            return as_int(last.get("total_tokens"))
    return 0


def local_day_start_epoch(now: float) -> float:
    local_now = datetime.fromtimestamp(now).astimezone()
    start = local_now.replace(hour=0, minute=0, second=0, microsecond=0)
    return start.timestamp()


def load_activity_state() -> dict:
    try:
        state = json.loads(ACTIVITY_FILE.read_text())
        if isinstance(state, dict) and state.get("schemaVersion") == ACTIVITY_SCHEMA_VERSION:
            return state
    except Exception:
        pass
    return {"schemaVersion": ACTIVITY_SCHEMA_VERSION, "files": {}, "events": [], "rateLimitEvents": []}


def scan_activity() -> tuple[int, int, dict[int, dict]]:
    """Incrementally process appended token_count records.

    Codex sessions record cumulative token snapshots. Counting deltas between
    cumulative totals deduplicates repeated unchanged snapshots while preserving
    cached-token-heavy long-session activity as local activity, not quota limit.
    The same pass records validated general Codex rate-limit windows, avoiding a
    separate full session scan every refresh.
    """
    roots = [CODEX_HOME / "sessions", CODEX_HOME / "archived_sessions"]
    now = now_epoch()
    day_start = local_day_start_epoch(now)
    keep_after = min(now - 3600, day_start) - 60
    state = load_activity_state()
    files = state.get("files") if isinstance(state.get("files"), dict) else {}
    events = state.get("events") if isinstance(state.get("events"), list) else []
    rate_limit_events = state.get("rateLimitEvents") if isinstance(state.get("rateLimitEvents"), list) else []
    initial_rate_limit_scan = not files and not rate_limit_events

    pruned_events = []
    for item in events:
        try:
            ts, tok = float(item[0]), int(item[1])
        except Exception:
            continue
        if ts >= keep_after and tok > 0:
            pruned_events.append([ts, tok])
    events = pruned_events

    pruned_rate_limits = []
    for item in rate_limit_events:
        try:
            minutes = as_int(item.get("minutes"))
            reset = as_int(item.get("reset"))
            event_epoch = as_float(item.get("eventEpoch"))
            timestamp = str(item.get("timestamp") or "")
            if minutes <= 0 or reset <= now or event_epoch <= 0:
                continue
            if event_epoch > now + EVENT_CLOCK_SKEW_SECS:
                continue
            if reset <= event_epoch:
                continue
            if reset - event_epoch > minutes * 60 + RESET_PLAUSIBILITY_SLOP_SECS:
                continue
            pruned_rate_limits.append(item)
        except Exception:
            continue
    rate_limit_events = pruned_rate_limits

    def compact_rate_limit_events(items: list[dict]) -> list[dict]:
        latest: dict[int, dict] = {}
        for item in items:
            minutes = as_int(item.get("minutes"))
            if minutes <= 0:
                continue
            current = latest.get(minutes)
            if current is None or str(item.get("timestamp") or "") >= str(current.get("timestamp") or ""):
                latest[minutes] = item
        return [latest[minutes] for minutes in sorted(latest.keys())]

    rate_limit_events = compact_rate_limit_events(rate_limit_events)

    def upsert_rate_limit_event(item: dict) -> None:
        minutes = as_int(item.get("minutes"))
        if minutes <= 0:
            return
        replacement = None
        kept = []
        for existing in rate_limit_events:
            if as_int(existing.get("minutes")) != minutes:
                kept.append(existing)
                continue
            if replacement is None or str(existing.get("timestamp") or "") > str(replacement.get("timestamp") or ""):
                replacement = existing
        if replacement is None or str(item.get("timestamp") or "") >= str(replacement.get("timestamp") or ""):
            replacement = item
        if replacement is not None:
            kept.append(replacement)
        rate_limit_events[:] = kept

    for root in roots:
        if not root.exists():
            continue
        for p in root.rglob("*.jsonl"):
            try:
                st = p.stat()
            except OSError:
                continue
            if st.st_mtime < keep_after and str(p) not in files and not initial_rate_limit_scan:
                continue
            key = str(p)
            meta = files.get(key) if isinstance(files.get(key), dict) else {}
            pos = as_int(meta.get("pos")) if st.st_size >= as_int(meta.get("pos")) else 0
            last_total = as_int(meta.get("last_total")) if pos > 0 else 0
            if pos == st.st_size and as_float(meta.get("mtime")) == st.st_mtime:
                continue
            try:
                with p.open(errors="replace") as fh:
                    fh.seek(pos)
                    for raw in fh:
                        if '"token_count"' not in raw:
                            continue
                        try:
                            ev = json.loads(raw)
                        except Exception:
                            continue
                        payload = ev.get("payload") or {}
                        if payload.get("type") != "token_count":
                            continue
                        ts = iso_epoch(str(ev.get("timestamp") or ""))
                        if ts <= 0:
                            continue
                        rate_limits = payload.get("rate_limits") or {}
                        for candidate in session_rate_limit_candidates(
                                rate_limits, str(ev.get("timestamp") or ""), now):
                            upsert_rate_limit_event({
                                "minutes": candidate["minutes"],
                                "kind": candidate["kind"],
                                "label": candidate["label"],
                                "utilization": candidate["utilization"],
                                "reset": candidate["reset"],
                                "source": "session",
                                "timestamp": candidate["_timestamp"],
                                "eventEpoch": candidate["_eventEpoch"],
                            })
                        info = payload.get("info") or {}
                        total = token_total(info)
                        if total is not None:
                            delta = total - last_total if total >= last_total else total
                            last_total = total
                        else:
                            delta = token_last(info)
                        if delta > 0:
                            events.append([ts, int(delta)])
                    pos = fh.tell()
            except OSError:
                continue
            files[key] = {"pos": pos, "mtime": st.st_mtime, "size": st.st_size, "last_total": last_total}

    recent = today = 0
    today_date = datetime.fromtimestamp(now).astimezone().date()
    for ts, tok in events:
        if ts >= now - 3600:
            recent += int(tok)
        if datetime.fromtimestamp(ts).astimezone().date() == today_date:
            today += int(tok)

    best_windows: dict[int, dict] = {}
    for item in rate_limit_events:
        minutes = as_int(item.get("minutes"))
        if minutes <= 0:
            continue
        current = best_windows.get(minutes)
        if current is None or str(item.get("timestamp") or "") > str(current.get("_timestamp") or ""):
            best_windows[minutes] = {
                "kind": str(item.get("kind") or ""),
                "minutes": minutes,
                "label": str(item.get("label") or window_label(minutes)),
                "utilization": as_float(item.get("utilization")),
                "reset": as_int(item.get("reset")),
                "source": "session",
                "_timestamp": str(item.get("timestamp") or ""),
                "_eventEpoch": as_float(item.get("eventEpoch")),
            }

    state = {
        "schemaVersion": ACTIVITY_SCHEMA_VERSION,
        "files": files,
        "events": events,
        "rateLimitEvents": rate_limit_events,
    }
    try:
        atomic_write_json(ACTIVITY_FILE, state)
    except Exception as e:
        sys.stderr.write(f"activity cache write failed: {e}\n")
    return recent, today, best_windows


def main():
    data = fetch_env() or fetch_rpc() or fetch_rollout()

    if not data:
        # keep the last numbers on screen, marked stale
        if CACHE_FILE.exists():
            try:
                cur = json.loads(CACHE_FILE.read_text())
                cur["_source"] = "stale"
                atomic_write_json(CACHE_FILE, cur)
            except Exception:
                pass
        return

    buckets = normalize_buckets(data)
    recent_tok, today_tok, session_windows = scan_activity()
    supplement_missing_general_windows_from_sessions(buckets, session_windows)
    general = general_bucket(buckets)
    windows = general.get("windows") or []
    max_util, quota_bucket, quota_window_label = quota_window(general)
    reached_type = str(general.get("rateLimitReachedType") or "")

    out = {
        "schemaVersion":  3,
        "buckets":        buckets,
        "windows":        windows,
        "5h-utilization": "",
        "5h-reset":       "",
        "7d-utilization": "",
        "7d-reset":       "",
        "updated_at":     datetime.now().strftime("%H:%M:%S"),
        "_source":        data["source"],
        "_plan":          str(general.get("plan") or data.get("plan") or ""),
        "_quota_bucket":  quota_bucket,
        "_quota_window":  quota_window_label,
        "_limit_reached_type": reached_type,
        "_rate_per_hour": recent_tok,
        "_rate_label":    "Local activity (1h, incl. cached)",
        "_today_tokens":  today_tok,
        "status": "rejected" if reached_type or max_util >= 1.0
                  else "allowed_warning" if max_util >= 0.9
                  else "allowed",
    }
    for window in windows:
        if window["minutes"] == 300:
            out["5h-utilization"] = f"{window['utilization']:.4f}"
            out["5h-reset"] = str(window["reset"])
        elif window["minutes"] == 10080:
            out["7d-utilization"] = f"{window['utilization']:.4f}"
            out["7d-reset"] = str(window["reset"])
    atomic_write_json(CACHE_FILE, out)


if __name__ == "__main__":
    main()
